# SupplyMind AI — Environment Variables
# Copy this file to .env and fill in your keys
# App runs fully without keys — all features work in demo mode

# Gemini AI — https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# Google Maps (optional — OpenStreetMap used by default)
GOOGLE_MAPS_API_KEY=

# Flask
SECRET_KEY=change-this-in-production
FLASK_ENV=development
PORT=5000
